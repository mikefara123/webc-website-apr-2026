# WebCentriq — required environment variables
# Copy to .env.local for local dev with `vercel dev`.
# In production, set these in the Vercel dashboard (Settings → Environment Variables).

# ---- Required ----

# Anthropic Claude API key (from https://console.anthropic.com/)
# Used by the estimator to generate timeline + cost + scope from a project description.
ANTHROPIC_API_KEY=sk-ant-api03-...

# Resend API key (from https://resend.com/api-keys)
# Used to send the estimate email to the lead + internal notification to sales.
RESEND_API_KEY=re_...

# ---- Optional (sensible defaults if unset) ----

# From address on outbound emails. Domain must be verified in Resend.
# Default: "WebCentriq <estimator@webcentriq.com>"
ESTIMATOR_FROM="WebCentriq <estimator@webcentriq.com>"

# Where internal lead notifications land. Reply-to on user emails is set to this.
# Default: "sales@webcentriq.com"
ESTIMATOR_SALES_TO=sales@webcentriq.com

# Claude model override. Defaults to claude-sonnet-4-6.
# Options: claude-sonnet-4-6 (default), claude-haiku-4-5-20251001 (faster/cheaper), claude-opus-4-7 (highest quality)
# ANTHROPIC_MODEL=claude-sonnet-4-6
